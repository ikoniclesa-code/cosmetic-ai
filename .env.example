# ===========================================
# Cosmetic AI — Environment Variables
# ===========================================
# Kopiraj ovaj fajl u .env.local i popuni vrednosti
# NIKAD ne commituj .env.local u Git!

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe Price IDs (kreiraš ih u Stripe Dashboard-u)
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PRO_PLUS_MONTHLY=
STRIPE_PRICE_PRO_PLUS_YEARLY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Google Gemini ---
GOOGLE_GEMINI_API_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:4000
